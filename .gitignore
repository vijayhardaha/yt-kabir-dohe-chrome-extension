# ==============================================================================
# GIT IGNORE RULES
# ==============================================================================
# Purpose: Excludes generated, machine-local, and third-party artifacts from
# version control to keep commits clean and reproducible.
# Docs: https://git-scm.com/docs/gitignore
# ==============================================================================

# ==========================================
# LOGS
# ==========================================
# Ignore runtime logs created locally during development.
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*
.pnpm-debug.log*

# ==========================================
# DIAGNOSTIC REPORTS
# ==========================================
# Ignore Node.js diagnostic reports generated during crashes.
# See: https://nodejs.org/api/report.html
report.[0-9]*.[0-9]*.[0-9]*.[0-9]*.json

# ==========================================
# RUNTIME DATA
# ==========================================
# Ignore PID/lock artifacts generated by local process runs.
pids
*.pid
*.seed
*.pid.lock

# ==========================================
# COVERAGE & INSTRUMENTATION
# ==========================================
# Ignore coverage and instrumentation output.
lib-cov
coverage
*.lcov
.nyc_output

# ==========================================
# TASK RUNNER / BUILD CACHES
# ==========================================
# Ignore build and task-runner caches.
.grunt
.cache
.parcel-cache
.fusebox/

# ==========================================
# DEPENDENCIES
# ==========================================
# Ignore vendored dependencies restored by package managers.
bower_components
node_modules/
jspm_packages/
web_modules/

# ==========================================
# PLATFORM / TOOLCHAIN ARTIFACTS
# ==========================================
# Ignore platform and toolchain artifacts.
.lock-wscript
build/Release
*.tsbuildinfo
.npm
.eslintcache
.stylelintcache
.rpt2_cache/
.rts2_cache_cjs/
.rts2_cache_es/
.rts2_cache_umd/
.node_repl_history
*.tgz
.yarn-integrity

# ==========================================
# ENVIRONMENT FILES
# ==========================================
# Ignore local environment files that may contain machine-specific secrets.
.env
.env.development.local
.env.test.local
.env.production.local
.env.local

# ==========================================
# FRAMEWORK OUTPUTS
# ==========================================
# Ignore framework and build output directories.
.next
out
.nuxt
dist
.cache/
.vuepress/dist
.temp
.docusaurus

# ==========================================
# SERVERLESS / LOCAL SERVICES
# ==========================================
# Ignore local service output and serverless packaging artifacts.
.serverless/
.dynamodb/
.tern-port

# ==========================================
# VS CODE EXTENSION TESTING
# ==========================================
# Ignore local VS Code binaries downloaded by extension test harness.
.vscode-test

# ==========================================
# YARN V2+
# ==========================================
# Ignore Yarn Berry generated install state.
.yarn/cache
.yarn/unplugged
.yarn/build-state.yml
.yarn/install-state.gz
.pnp.*

# ==========================================
# OS-SPECIFIC FILES
# ==========================================
# Ignore operating-system metadata files.
.DS_Store
Thumbs.db

# ==========================================
# DEPLOYMENT TOOLING
# ==========================================
# Ignore local deployment tooling state.
.netlify
