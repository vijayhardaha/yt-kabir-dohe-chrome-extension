# ==============================================================================
# GIT IGNORE RULES
# ==============================================================================
# Purpose: Excludes generated, machine-local, and third-party artifacts from
# version control to keep commits clean and reproducible.
# Docs: https://git-scm.com/docs/gitignore
# ==============================================================================

# ==========================================
# LOGS
# ==========================================
# Why: Runtime logs are environment-specific and not source-controlled assets.
# Default: Git tracks any file not matched by ignore patterns.
# Use Case: Avoids noisy commits from local run/debug sessions.
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*
.pnpm-debug.log*

# ==========================================
# DIAGNOSTIC REPORTS
# ==========================================
# Why: Node diagnostics are generated at runtime for troubleshooting.
# Default: Report files are tracked unless explicitly ignored.
# Use Case: Keeps crash analysis artifacts local to the developer machine.
# See: https://nodejs.org/api/report.html
report.[0-9]*.[0-9]*.[0-9]*.[0-9]*.json

# ==========================================
# RUNTIME DATA
# ==========================================
# Why: PID and lock artifacts are process-specific ephemeral files.
# Default: These files may be tracked if left unignored.
# Use Case: Prevents accidental commits from local service runs.
pids
*.pid
*.seed
*.pid.lock

# ==========================================
# COVERAGE & INSTRUMENTATION
# ==========================================
# Why: Instrumented and coverage outputs are generated artifacts.
# Default: Included in git status unless ignored.
# Use Case: Keeps repo history focused on source changes.
lib-cov
coverage
*.lcov
.nyc_output

# ==========================================
# TASK RUNNER / BUILD CACHES
# ==========================================
# Why: Build-system caches are machine-local and regenerate automatically.
# Default: Cached files are tracked if omitted here.
# Use Case: Reduces churn and merge conflicts in cache directories.
.grunt
.cache
.parcel-cache
.fusebox/

# ==========================================
# DEPENDENCIES
# ==========================================
# Why: Third-party dependencies are reproducible via package manager lockfiles.
# Default: Vendor directories can otherwise be committed by mistake.
# Use Case: Avoids bloating repository size with external code.
bower_components
node_modules/
jspm_packages/
web_modules/

# ==========================================
# PLATFORM / TOOLCHAIN ARTIFACTS
# ==========================================
# Why: Tool-generated outputs and caches are not hand-authored source.
# Default: Git will track these unless excluded.
# Use Case: Keeps local tool state out of commits.
.lock-wscript
build/Release
*.tsbuildinfo
.npm
.eslintcache
.stylelintcache
.rpt2_cache/
.rts2_cache_cjs/
.rts2_cache_es/
.rts2_cache_umd/
.node_repl_history
*.tgz
.yarn-integrity

# ==========================================
# ENVIRONMENT FILES
# ==========================================
# Why: Environment files can contain machine-specific or sensitive values.
# Default: .env files are tracked unless ignored.
# Use Case: Prevents leaking local secrets and deployment-specific values.
.env
.env.development.local
.env.test.local
.env.production.local
.env.local

# ==========================================
# FRAMEWORK OUTPUTS
# ==========================================
# Why: Framework build output is generated at runtime/build time.
# Default: Build directories are tracked when not ignored.
# Use Case: Keeps deployment artifacts out of source history.
.next
out
.nuxt
dist
.cache/
.vuepress/dist
.temp
.docusaurus

# ==========================================
# SERVERLESS / LOCAL SERVICES
# ==========================================
# Why: Local service state and deployment bundles are generated content.
# Default: Service directories may be tracked if omitted.
# Use Case: Keeps infrastructure-side artifacts out of version control.
.serverless/
.dynamodb/
.tern-port

# ==========================================
# VS CODE EXTENSION TESTING
# ==========================================
# Why: VS Code test harness downloads editor binaries locally.
# Default: Downloaded binaries appear as untracked files.
# Use Case: Avoids large binary check-ins from extension test runs.
.vscode-test

# ==========================================
# YARN V2+
# ==========================================
# Why: Local Yarn state files are generated by install operations.
# Default: Some Yarn artifacts can appear as untracked files.
# Use Case: Keeps lock-managed dependency state clean.
.yarn/cache
.yarn/unplugged
.yarn/build-state.yml
.yarn/install-state.gz
.pnp.*

# ==========================================
# OS-SPECIFIC FILES
# ==========================================
# Why: Finder/Explorer metadata is machine-specific noise.
# Default: OS may create these files automatically.
# Use Case: Prevents accidental commit of desktop metadata files.
.DS_Store
Thumbs.db

# ==========================================
# DEPLOYMENT TOOLING
# ==========================================
# Why: Netlify local folder is generated by local tooling.
# Default: Tracked unless ignored.
# Use Case: Keeps deployment helper state local.
.netlify
