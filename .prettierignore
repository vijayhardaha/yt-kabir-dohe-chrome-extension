# ==============================================================================
# PRETTIER EXCLUSION RULES
# ==============================================================================
# Purpose: Tells Prettier which paths to skip so formatting only runs on
# human-authored files and avoids generated or vendor-managed artifacts.
# Docs: https://prettier.io/docs/ignore
# ==============================================================================

# ==========================================
# VCS & DEPENDENCIES
# ==========================================
# Skip Git internals.
.git
# Skip installed dependencies.
node_modules

# ==========================================
# BUILD OUTPUTS
# ==========================================
# Skip generated distribution files.
dist
# Skip generated output directories.
out
# Skip generated script artifacts.
lib/scripts

# ==========================================
# STATIC GENERATED ASSETS
# ==========================================
# Skip machine-generated static assets.
public/static

# ==========================================
# PLAIN TEXT CONFIG FILES
# ==========================================
# Skip .editorconfig because Prettier parser inference is not available.
.editorconfig
# Skip .gitignore because Prettier parser inference is not available.
.gitignore
# Skip .prettierignore to avoid self-format parser inference errors.
.prettierignore
