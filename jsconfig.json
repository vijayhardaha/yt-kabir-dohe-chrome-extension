{
	// ==============================================================================
	// JAVASCRIPT INTELLIGENCE CONFIG
	// ==============================================================================
	// Purpose: Configures editor tooling behavior for JavaScript files in this
	// extension workspace, including path alias intelligence.
	// Docs: https://code.visualstudio.com/docs/languages/jsconfig
	// ==============================================================================

	// ==========================================
	// COMPILER OPTIONS
	// ==========================================
	"compilerOptions": {
		// Map @/* imports to the src directory for autocomplete and navigation.
		"paths": { "@/*": ["./src/*"] }
	}
}
