# ==============================================================================
# EDITORCONFIG STYLE CONTRACT
# ==============================================================================
# Purpose: Defines editor-level formatting defaults so contributors and CI
# produce consistent whitespace and line-ending behavior.
# Docs: https://editorconfig.org/
# ==============================================================================

# ==========================================
# ROOT CONTROL
# ==========================================
# Stop searching for parent .editorconfig files outside this repository.
root = true

# ==========================================
# GLOBAL DEFAULTS
# ==========================================
[*]
# Force UTF-8 to avoid encoding drift across tools and platforms.
charset = utf-8
# Use LF to prevent cross-platform line-ending diffs in Git.
end_of_line = lf
# Default to tabs for repository-wide indentation.
indent_style = tab
# Use a visual width of 4 for tab indentation in non-code files.
indent_size = 4
# Ensure every file ends with a newline for POSIX-friendly tooling.
insert_final_newline = true
# Remove trailing spaces by default to keep diffs clean.
trim_trailing_whitespace = true

# ==========================================
# PLAIN TEXT OVERRIDES
# ==========================================
[*.txt]
# Preserve intentional trailing spaces in plain text content.
trim_trailing_whitespace = false

# ==========================================
# MARKUP OVERRIDES
# ==========================================
[*.{md,yml}]
# Use spaces in markup files where visual alignment is common.
indent_style = space
# Keep 2-space indentation for markdown/yaml readability.
indent_size = 2
# Preserve markdown/yaml trailing spaces when intentionally used.
trim_trailing_whitespace = false

# ==========================================
# JSON OVERRIDES
# ==========================================
[*.json]
# Keep JSON indentation aligned with project formatter output.
indent_size = 2
# Avoid trimming JSON trailing spaces aggressively in editor workflows.
trim_trailing_whitespace = false

# ==========================================
# SCRIPT OVERRIDES
# ==========================================
[*.{js,mjs,cjs,jsx,ts,tsx}]
# Match JS/TS indentation width with project formatter defaults.
indent_size = 2
