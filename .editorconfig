# ==============================================================================
# EDITORCONFIG STYLE CONTRACT
# ==============================================================================
# Purpose: Defines shared editor behavior so formatting remains consistent
# across local development, CI checks, and pull requests.
# Docs: https://editorconfig.org/
# ==============================================================================

# ==========================================
# GLOBAL POLICY
# ==========================================
# Why: Mark this file as the top-most EditorConfig so no parent rules leak in.
# Default: false (parent .editorconfig files may continue to apply).
# Use Case: Keeps this extension repository fully self-contained.
root = true

# Why: Establish a stable baseline for all files unless overridden below.
# Default: Editor-specific behavior can differ across machines.
# Use Case: Avoids inconsistent diffs from encoding, EOL, or trailing whitespace.
[*]
charset = utf-8
end_of_line = lf
indent_style = tab
indent_size = 4
insert_final_newline = true
trim_trailing_whitespace = true

# ==========================================
# TEXT CONTENT OVERRIDES
# ==========================================
# Why: Preserve intentional spacing in plain text artifacts.
# Default: Inherits true from the global policy above.
# Use Case: Keeps text samples and fixture-like notes intact.
[*.txt]
trim_trailing_whitespace = false

# ==========================================
# DOCUMENTATION & MARKUP OVERRIDES
# ==========================================
# Why: Markdown and YAML often use alignment or trailing spaces intentionally.
# Default: Inherits trimming and base indentation from global policy.
# Use Case: Prevents accidental markdown rendering changes.
[*.{md,yml}]
indent_style = space
indent_size = 2
trim_trailing_whitespace = false

# ==========================================
# JSON OVERRIDES
# ==========================================
# Why: Keep JSON indentation tab-based per project convention.
# Default: Inherits space indentation from global policy.
# Use Case: Matches existing repository JSON formatting.
[*.json]
indent_size = 2
trim_trailing_whitespace = false

# ==========================================
# SCRIPTING OVERRIDES
# ==========================================
# Why: Enforce 2-space indentation in JS/TS ecosystem files.
# Default: Inherits global indentation if omitted.
# Use Case: Aligns with ESLint + Prettier output for source code.
[*.{js,mjs,cjs,jsx,ts,tsx}]
indent_size = 2
